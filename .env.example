# SwiftList Environment Variables
# Copy this file to .env and fill in your values

# ============================================================================
# SUPABASE
# ============================================================================
VITE_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================================
# GOOGLE AI (Gemini — used for image generation and vision analysis)
# ============================================================================
GOOGLE_AI_API_KEY=your-google-ai-api-key

# ============================================================================
# ANTHROPIC (Claude — used for text generation and Lifeguard monitoring)
# ============================================================================
ANTHROPIC_API_KEY=your-anthropic-api-key

# ============================================================================
# IMAGE PROCESSING
# ============================================================================
REPLICATE_API_KEY=your-replicate-api-key
REPLICATE_API_TOKEN=your-replicate-api-token
FAL_KEY=your-fal-ai-key

# ============================================================================
# STRIPE (Payments)
# ============================================================================
STRIPE_SECRET_KEY=sk_test_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
VITE_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key

# ============================================================================
# REDIS / BULLMQ (Job Queue)
# ============================================================================
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# ============================================================================
# RATE LIMITING (Upstash)
# ============================================================================
UPSTASH_REDIS_REST_URL=your-upstash-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ============================================================================
# ADMIN
# ============================================================================
ADMIN_USER_IDS=your-admin-uuid
