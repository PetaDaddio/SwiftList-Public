# SwiftList Workers Environment Configuration
# Copy this file to .env and fill in your API keys

# =============================================================================
# INFRASTRUCTURE
# =============================================================================

NODE_ENV=production
PORT=3000
WORKER_CONCURRENCY=5

# Redis (provided by Railway.app)
REDIS_HOST=your-redis-host.railway.internal
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Sentry (Error Tracking)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# =============================================================================
# AI APIs - PHASE 1: CRITICAL (Required for MVP)
# =============================================================================

# Google Vertex AI (WF-01, WF-02, WF-05, WF-10, WF-23, WF-24)
# Used by: The Decider, Jewelry Engine, Furniture Engine, Product Description
GOOGLE_VERTEX_KEY=your-google-vertex-api-key
GOOGLE_PROJECT_ID=your-google-project-id

# Photoroom (WF-07)
# Used by: Background Removal (MOST USED WORKFLOW - 80% margin)
PHOTOROOM_API_KEY=your-photoroom-api-key

# Anthropic (WF-11, WF-12, WF-13, WF-20)
# Used by: Social media posts (Twitter, Instagram, Facebook), SEO Blog
ANTHROPIC_API_KEY=your-anthropic-api-key

# =============================================================================
# AI APIs - PHASE 2: ESSENTIAL PRODUCT ENGINES
# =============================================================================

# Stability AI (WF-06)
# Used by: General Goods Engine (97% margin)
STABILITY_API_KEY=your-stability-api-key

# Replicate (WF-02)
# Used by: Jewelry Precision Engine
REPLICATE_API_KEY=your-replicate-api-key

# RunwayML (WF-03, WF-18)
# Used by: Fashion Engine, Animated Product
RUNWAYML_API_KEY=your-runwayml-api-key

# OpenAI (WF-04, WF-17)
# Used by: Glass Refraction Engine, Generate Preset
OPENAI_API_KEY=your-openai-api-key

# =============================================================================
# AI APIs - PHASE 3: CONTENT GENERATION
# =============================================================================

# (Anthropic key already listed in Phase 1)

# =============================================================================
# AI APIs - PHASE 4: IMAGE ENHANCEMENT
# =============================================================================

# Fal.ai (WF-09)
# Used by: Lifestyle Setting
FAL_API_KEY=your-fal-api-key

# Magnific AI (WF-14)
# Used by: High-Res Upscale (96% margin)
MAGNIFIC_API_KEY=your-magnific-api-key

# Recraft AI (WF-15)
# Used by: Vector Model (97.8% margin)
RECRAFT_API_KEY=your-recraft-api-key

# Vectorizer.ai (WF-16)
# Used by: SVG Creation (98.9% margin - EXTREMELY HIGH)
VECTORIZER_API_KEY=your-vectorizer-api-key

# =============================================================================
# AI APIs - PHASE 5: ADVANCED FEATURES
# =============================================================================

# ElevenLabs (WF-22)
# Used by: Blog to YouTube (TTS)
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# Luma Labs (WF-22)
# Used by: Blog to YouTube (Video Generation)
LUMA_API_KEY=your-luma-api-key

# Vizard.ai (WF-21)
# Used by: YouTube to TikTok (Video Repurpose)
VIZARD_API_KEY=your-vizard-api-key

# =============================================================================
# PAYMENT & BILLING
# =============================================================================

# Stripe (WF-26)
# Used by: Billing & Top-Up
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# =============================================================================
# LOCAL PROCESSING (No API keys needed)
# =============================================================================

# GraphicsMagick (WF-08, WF-25) - Installed in Docker
# Sharp.js (WF-19) - NPM package
# FFmpeg (WF-21, WF-22) - Installed in Docker

# =============================================================================
# DEPLOYMENT NOTES
# =============================================================================

# Railway.app:
# - Redis is automatically provisioned (REDIS_* vars injected)
# - Set all API keys in Railway dashboard
# - Enable auto-scaling: 1-3 workers based on queue depth
# - Budget: $15/mo (Redis $5 + Workers $10)

# Estimated Monthly API Costs: $85.50
# Average Margin: 93.2%
