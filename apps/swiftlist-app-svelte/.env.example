# ============================================================================
# SWIFTLIST ENVIRONMENT VARIABLES
# ============================================================================
# Copy to .env.local for local development:  cp .env.example .env.local
# Never commit .env.local or .env.production to git!

# ============================================================================
# SUPABASE (Required)
# Get keys from: https://app.supabase.com/project/_/settings/api
# ============================================================================
VITE_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
VITE_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================================
# REDIS (Required — for BullMQ job queue)
# Railway provides REDIS_URL automatically; individual vars work too
# ============================================================================
# Option A: Single URL (Railway default)
REDIS_URL=redis://default:password@host:port
# Option B: Individual vars (alternative)
# REDIS_HOST=your-redis-host.railway.app
# REDIS_PORT=6379
# REDIS_PASSWORD=your-redis-password

# ============================================================================
# AI API KEYS (Required)
# ============================================================================
# Anthropic Claude — Lifeguard error monitoring + job assistant
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-key

# Google Gemini 2.0 Flash — image classification + scene analysis
# Get from: https://aistudio.google.com/apikey
GOOGLE_GEMINI_API_KEY=your-google-gemini-key

# Replicate — background removal fallback + image processing
# Get from: https://replicate.com/account/api-tokens
REPLICATE_API_KEY=your-replicate-key

# fal.ai — BRIA RMBG 2.0 (primary background removal)
# Get from: https://fal.ai/dashboard/keys
FAL_KEY=your-fal-key

# ============================================================================
# ERROR TRACKING (Recommended)
# ============================================================================
# Sentry DSN — error tracking for both client and server
# Get from: https://sentry.io/settings/projects/
VITE_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Sentry auth token — for source map uploads during build only
# Get from: https://sentry.io/settings/auth-tokens/
SENTRY_AUTH_TOKEN=your-sentry-token

# ============================================================================
# INTEGRATIONS (Optional)
# ============================================================================
# Slack webhook — Lifeguard error alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ============================================================================
# APPLICATION CONFIG
# ============================================================================
# Origin URL — SvelteKit uses this for CSRF protection (adapter-node)
# In dev, defaults to http://localhost:5173
ORIGIN=https://swiftlist.app

NODE_ENV=development

# ============================================================================
# STRIPE
# ============================================================================
STRIPE_SECRET_KEY=your-stripe-secret-key
VITE_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# Stripe Price IDs (one-time credit packs)
STRIPE_PRICE_CREDITS_100=price_...
STRIPE_PRICE_CREDITS_500=price_...
STRIPE_PRICE_CREDITS_1500=price_...

# Stripe Price IDs (monthly subscriptions)
STRIPE_PRICE_MAKER_MONTHLY=price_...
STRIPE_PRICE_MERCHANT_MONTHLY=price_...

# ============================================================================
# CLOUDFLARE TURNSTILE (Bot protection on auth forms)
# Get from: https://dash.cloudflare.com → Turnstile → Add Site
# ============================================================================
VITE_PUBLIC_CLOUDFLARE_TURNSTILE_SITE_KEY=your-turnstile-site-key
CLOUDFLARE_TURNSTILE_SECRET_KEY=your-turnstile-secret-key
